# Shopify Configuration
# Copy this file to .env and fill in your values

# Your Shopify store domain
VITE_SHOPIFY_STORE_DOMAIN=epicentrodigital-ec.myshopify.com

# Storefront API Access Token (from Shopify Admin > Headless > Storefront API)
# Get it at: https://admin.shopify.com/store/[store]/headless/[id]/storefront_api
VITE_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_token_here
